# ═══════════════════════════════════════════════════════════════
# streaming-auth — secrets & env overrides
# YAML in config/default.yaml holds defaults; env wins over YAML.
# Generate a real .env via the setup script; never commit .env.
# ═══════════════════════════════════════════════════════════════

# ─── Required secrets ────────────────────────────────────────────
# Bearer token backend must send on POST /sign and POST /sign/publish
SIGN_API_TOKEN=change-me-64-hex

# ─── Publish URL signing (txSecret/txTime) ───────────────────────
# /sign/publish and /srs/publish fail closed until these are set.
PUBLISH_DOMAIN=bspush.example.com
PUBLISH_APP=luckylive
PUBLISH_SIGN_KEY=change-me-64-hex

# Emit `url_rtmps` in /sign/publish only after a Let's Encrypt cert is
# bound to :PUBLISH_RTMPS_PORT (the CF Origin Cert is rejected by OBS).
# PUBLISH_RTMPS_ENABLED=false
# PUBLISH_RTMPS_PORT=1936

# ─── BunnyCDN — /sign fails closed with 503 until both are set ───
BUNNY_TOKEN_KEY=
BUNNY_CDN_URL=

# ─── Optional env overrides (override YAML values) ───────────────
# PORT=3000
# BIND_IP=0.0.0.0
# LOG_LEVEL=info
# CORS_ORIGINS=*
# ORIGIN_HOST=10.40.96.4
# ORIGIN_PORT=8080
# NODE_ENV=production

# Optional SRS API creds (consumed by external monitoring, not this service)
# SRS_API_USER=admin
# SRS_API_PASS=change-me
